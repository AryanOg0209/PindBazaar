generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  farmer
  industry
  baler
  mover
  admin
}

enum Status {
  pending
  approved
  rejected
}

enum Direction {
  inbound
  outbound
}

enum ListingType {
  demand
  supply
  job
}

enum ListingStatus {
  active
  fulfilled
  cancelled
}

enum OrderStatus {
  pending
  accepted
  in_progress
  completed
  cancelled
}

model User {
  id           String    @id @default(uuid())
  phone        String    @unique
  name         String?
  email        String?   @unique
  role         Role
  status       Status    @default(pending)
  adminNotes   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  otpCodes        OtpCode[]
  farmerProfile   FarmerProfile?
  industryProfile IndustryProfile?
  balerProfile    BalerProfile?
  moverProfile    MoverProfile?
  documents       Document[]
  
  listings        Listing[]
  ordersAsClient  Order[]       @relation("ClientOrders")
  ordersAsWorker  Order[]       @relation("WorkerOrders")
  reviewsReceived Review[]      @relation("ReviewsReceived")
  reviewsGiven    Review[]      @relation("ReviewsGiven")
  messagesSent    Message[]     @relation("MessagesSent")
  messagesReceived Message[]    @relation("MessagesReceived")
  notifications   Notification[]
  aadhaarVerification AadhaarVerification?

  @@map("users")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String?
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("otp_codes")
}

model FarmerProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  fullName      String
  village       String
  state         String
  district      String
  pincode       String
  landAcres     Float?
  cropTypes     String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("farmer_profiles")
}

model IndustryProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  companyName     String
  contactPerson   String
  village         String
  state           String
  district        String
  pincode         String
  industryType    String
  gstNumber       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("industry_profiles")
}

model BalerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  fullName     String
  village      String
  state        String
  district     String
  pincode      String
  machineType  String   // square / round
  machineCount Int      @default(1)
  pricePerBale Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("baler_profiles")
}

model MoverProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  fullName     String
  village      String
  state        String
  district     String
  pincode      String
  vehicleType  String
  vehicleCount Int      @default(1)
  licenseNo    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("mover_profiles")
}

model Document {
  id         String   @id @default(uuid())
  userId     String
  docType    String
  fileUrl    String
  createdAt  DateTime @default(now())

  user         User                  @relation(fields: [userId], references: [id])
  verification AadhaarVerification?

  @@map("documents")
}

model District {
  id       String @id @default(uuid())
  state    String
  district String

  @@unique([state, district])
  @@map("districts")
}

model Listing {
  id          String        @id @default(uuid())
  userId      String
  type        ListingType   // demand, supply, job
  title       String
  description String?
  cropType    String?
  quantity    Float?        // in tons or acres
  price       Float?
  location    String        // village/district
  status      ListingStatus @default(active)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@map("listings")
}

model Order {
  id          String      @id @default(uuid())
  listingId   String
  clientId    String      // User who created the listing or requested work
  workerId    String      // User who accepted the job/supply
  status      OrderStatus @default(pending)
  agreedPrice Float
  scheduledFor DateTime?
  completedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  client  User    @relation("ClientOrders", fields: [clientId], references: [id])
  worker  User    @relation("WorkerOrders", fields: [workerId], references: [id])

  @@map("orders")
}

model Review {
  id         String   @id @default(uuid())
  reviewerId String
  targetId   String
  rating     Int      // 1 to 5
  comment    String?
  createdAt  DateTime @default(now())

  reviewer User @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  target   User @relation("ReviewsReceived", fields: [targetId], references: [id])

  @@map("reviews")
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("MessagesSent", fields: [senderId], references: [id])
  receiver User @relation("MessagesReceived", fields: [receiverId], references: [id])

  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // info, alert, success
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AadhaarVerification {
  id             String   @id @default(uuid())
  userId         String   @unique
  documentId     String   @unique

  parsedName     String?
  parsedDob      String?
  parsedGender   String?
  parsedAddress  String?
  parsedUidLast4 String?

  nameMatchScore    Float?
  addressMatchScore Float?
  fraudFlags        String[]
  isDocumentGenuine Boolean?

  trustScore  Int?
  trustLevel  String?

  aiSummary   String?

  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  document Document @relation(fields: [documentId], references: [id])

  @@map("aadhaar_verifications")
}
